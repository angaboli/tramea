# Tramea — variables d'environnement (copier en .env, NE PAS committer .env)

# Email(s) admin pour l'auth LOCALE de dev (séparés par des virgules).
# En production (Supabase), les admins se définissent dans la table profiles.
VITE_ADMIN_EMAIL=

# TEMPORAIRE : contourne l'auth et ouvre l'app en admin (le temps de stabiliser).
# Mettre =true pour désactiver la connexion ; remettre vide/false pour réactiver.
VITE_AUTH_DISABLED=

# Supabase (auth lien magique + données) — à renseigner pour l'adapter réel.
VITE_SUPABASE_URL=
# Clé publique : nouveau nom Supabase (sb_publishable_…). Jamais la clé service.
VITE_SUPABASE_PUBLISHABLE_KEY=
# (ancien nom toléré : VITE_SUPABASE_ANON_KEY)

# Clé d'api GEMINI pour pouvoir parser le programme
# Si la clé n'est pas renseignée, on utilise le parse classique
GEMINI_API_KEY=

# Verset biblique (api/bible-verse.ts) : aucune clé requise — proxy vers
# getBible.net (Louis Segond 1910, domaine public). Fonctionne uniquement en
# déploiement Vercel (ou `vercel dev`) : la fonction /api n'existe pas sous
# `pnpm dev` seul, l'insertion de verset échoue alors proprement (message
# d'erreur dans le dialogue), sans bloquer le reste de l'app.

# Lien vers le dossier ProPresenter complet (SharePoint/OneDrive) — bibliothèque
# "permanente" de référence (médias inclus). Affiché comme lien dans l'app à
# côté de la bibliothèque partagée (noms seulement). Changeable ici sans toucher
# au code.
VITE_LIBRARY_SHAREPOINT_URL=https://d3cod-my.sharepoint.com/:f:/p/on/IgBpkEk3Djd4R6tFQEBNzBeGAQQJ2VQsT3lps-AjdvvRexo?e=a6yemA
