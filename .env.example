# Tramea — variables d'environnement (copier en .env, NE PAS committer .env)

# Email de l'administrateur initial (auth locale de dev : accès admin immédiat).
VITE_ADMIN_EMAIL=

# Supabase (auth lien magique + données) — à renseigner pour l'adapter réel.
VITE_SUPABASE_URL=
# Clé publique : nouveau nom Supabase (sb_publishable_…). Jamais la clé service.
VITE_SUPABASE_PUBLISHABLE_KEY=
# (ancien nom toléré : VITE_SUPABASE_ANON_KEY)
