# Tramea — variables d'environnement (copier en .env, NE PAS committer .env)

# Email(s) admin pour l'auth LOCALE de dev (séparés par des virgules).
# En production (Supabase), les admins se définissent dans la table profiles.
VITE_ADMIN_EMAIL=

# TEMPORAIRE : contourne l'auth et ouvre l'app en admin (le temps de stabiliser).
# Mettre =true pour désactiver la connexion ; remettre vide/false pour réactiver.
VITE_AUTH_DISABLED=

# Supabase (auth lien magique + données) — à renseigner pour l'adapter réel.
VITE_SUPABASE_URL=
# Clé publique : nouveau nom Supabase (sb_publishable_…). Jamais la clé service.
VITE_SUPABASE_PUBLISHABLE_KEY=
# (ancien nom toléré : VITE_SUPABASE_ANON_KEY)
